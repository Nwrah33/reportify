<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head><meta charset="UTF-8"><title>{{title}}</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Cairo', 'Noto Sans Arabic', sans-serif; direction: rtl; text-align: right; color: #1e293b; padding: 40px; }
.header { text-align: center; padding: 32px; background: linear-gradient(135deg, #1e3a5f, #2563eb); color: #fff; border-radius: 12px; margin-bottom: 24px; }
.header h1 { font-size: 28px; margin-bottom: 4px; }
.header .title { font-size: 14px; opacity: 0.85; }
.two-col { display: grid; grid-template-columns: 1fr 2fr; gap: 24px; }
.sidebar { background: #f8fafc; border-radius: 12px; padding: 20px; }
.main { padding: 0; }
h2 { font-size: 16px; color: #1e3a5f; border-bottom: 2px solid #2563eb; padding-bottom: 6px; margin: 20px 0 12px; }
h2:first-child { margin-top: 0; }
.item { margin-bottom: 14px; }
.item h3 { font-size: 14px; color: #1e293b; }
.item .meta { font-size: 12px; color: #64748b; margin-bottom: 4px; }
.item p { font-size: 13px; line-height: 1.6; color: #475569; }
.skill { display: inline-block; background: #e2e8f0; border-radius: 4px; padding: 4px 10px; font-size: 12px; margin: 2px; }
ul { padding-right: 16px; }
li { font-size: 13px; margin-bottom: 4px; }
</style></head>
<body>
<div class="header">
  <h1>{{personal.name}}</h1>
  {{#if personal.title}}<div class="title">{{personal.title}}</div>{{/if}}
  {{#if personal.email}}<div style="font-size:12px;opacity:0.8;margin-top:8px;">{{personal.email}}{{#if personal.phone}} | {{personal.phone}}{{/if}}</div>{{/if}}
</div>

<div class="two-col">
  <div class="sidebar">
    <h2>المعلومات الشخصية</h2>
    {{#if personal.email}}<div class="item"><p>{{personal.email}}</p></div>{{/if}}
    {{#if personal.phone}}<div class="item"><p>{{personal.phone}}</p></div>{{/if}}
    {{#if personal.location}}<div class="item"><p>{{personal.location}}</p></div>{{/if}}

    {{#if skills}}
    <h2>المهارات</h2>
    <div>{{#each skills}}<span class="skill">{{this}}</span>{{/each}}</div>
    {{/if}}
  </div>

  <div class="main">
    {{#if summary}}<h2>ملخص</h2><p style="font-size:13px;line-height:1.8;">{{summary}}</p>{{/if}}

    {{#if experience}}
    <h2>الخبرات</h2>
    {{#each experience}}
    <div class="item">
      <h3>{{position}}</h3>
      <div class="meta">{{company}}{{#if period}} | {{period}}{{/if}}</div>
      <p>{{description}}</p>
    </div>
    {{/each}}
    {{/if}}

    {{#if education}}
    <h2>التعليم</h2>
    {{#each education}}
    <div class="item">
      <h3>{{degree}}</h3>
      <div class="meta">{{institution}}{{#if year}} | {{year}}{{/if}}</div>
    </div>
    {{/each}}
    {{/if}}
  </div>
</div>
</body>
</html>
